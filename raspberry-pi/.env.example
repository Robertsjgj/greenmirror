# GreenMirror — raspberry-pi backend environment variables
# Copy this file to .env and fill in real values.
# .env is git-ignored and never committed.
#
# All FIREBASE_* vars are OPTIONAL.
# Without them the server runs normally (in-memory only).

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5000
# USE_SIMULATION=true   # uncomment to run the sensor simulator

# ─── Greenhouse environment sensor (Raspberry Pi DHT11 via Linux IIO) ────────
# The Pi reads a DHT11 for greenhouse air temperature + humidity and feeds them
# into the live snapshot (environment.air_temp_c / humidity_pct). Reading is done
# through the kernel IIO driver (Node reads /sys/bus/iio/... with fs.readFile) —
# no native modules, no Python. Requires the device-tree overlay on the Pi (see
# README "Greenhouse environment sensor (DHT11)"). No light sensor exists, so
# light stays null. When disabled, live environment stays "unavailable" as before.
# Wiring: VCC → 3.3V, DATA → GPIO4 (physical pin 7), GND → GND.
ENVIRONMENT_ENABLED=true
ENVIRONMENT_SENSOR_TYPE=dht11
ENVIRONMENT_REFRESH_SECONDS=30       # background read cadence (seconds)
ENVIRONMENT_STALE_SECONDS=120        # after this long with no good read, values go null
# ENVIRONMENT_DHT_GPIO is DOCUMENTATION ONLY — the GPIO pin is set by the Pi
# device-tree overlay (dtoverlay=dht11,gpiopin=4 in config.txt), not by Node.
# Node locates the sensor by its IIO device name, so this value is not read.
ENVIRONMENT_DHT_GPIO=4

# ─── Firebase Admin (optional) ───────────────────────────────────────────────
# Option A: explicit inline credentials (no JSON file needed)
# Find these in Firebase Console → Project settings → Service accounts
# → Generate new private key → copy values from the downloaded JSON
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste the private_key value exactly — include the -----BEGIN/END----- lines.
# If the key contains literal \n sequences, they are converted automatically.
FIREBASE_PRIVATE_KEY=

# Option B: point to a downloaded service account JSON file
# (takes effect only if FIREBASE_CLIENT_EMAIL is not set)
# GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# ─── Firestore quota protection (write throttling) ───────────────────────────
# Sensors tick ~every 5s. Writing on every tick blows past Firestore's free
# tier and makes the app's listeners re-read constantly. These throttle how
# often the backend writes; raise them to save more quota, lower for fresher
# data. Defaults (used when unset): live 30000 (30s), history 300000 (5 min).
# FIRESTORE_LIVE_WRITE_INTERVAL_MS=30000      # latestReadings/{gh} overwrite cadence
# FIRESTORE_HISTORY_WRITE_INTERVAL_MS=300000  # readings/ history append cadence (1–5 min)

# ─── Debug ───────────────────────────────────────────────────────────────────
# FIRESTORE_VERBOSE=true   # log every successful Firestore write
