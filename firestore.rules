rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function currentUserProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function currentUserIsActive() {
      return signedIn()
        && currentUserProfile().active == true;
    }

    function currentUserIsAdmin() {
      return currentUserIsActive()
        && currentUserProfile().role == "admin";
    }

    function currentUserGreenhouseId() {
      return currentUserProfile().greenhouseId;
    }

    match /users/{uid} {
      allow read: if currentUserIsActive()
        && (
          request.auth.uid == uid
          || (
            currentUserIsAdmin()
            && resource.data.greenhouseId == currentUserGreenhouseId()
          )
        );

      allow write: if false;
    }

    match /wateringSettings/{greenhouseId} {
      allow read: if currentUserIsActive()
        && greenhouseId == currentUserGreenhouseId();

      allow create, update, delete: if currentUserIsAdmin()
        && greenhouseId == currentUserGreenhouseId();
    }

    match /wateringSchedules/{id} {
      allow read: if currentUserIsActive()
        && resource.data.greenhouseId == currentUserGreenhouseId()
        && (
          currentUserIsAdmin()
          || resource.data.assignedUserId == request.auth.uid
        );

      allow create: if currentUserIsAdmin()
        && request.resource.data.greenhouseId == currentUserGreenhouseId();

      allow update: if currentUserIsActive()
        && resource.data.greenhouseId == currentUserGreenhouseId()
        && request.resource.data.greenhouseId == resource.data.greenhouseId
        && (
          currentUserIsAdmin()
          || (
            resource.data.assignedUserId == request.auth.uid
            && request.resource.data.assignedUserId == request.auth.uid
          )
        );

      allow delete: if currentUserIsAdmin()
        && resource.data.greenhouseId == currentUserGreenhouseId();
    }

    match /latestReadings/{id} {
      allow read, write: if true;
    }

    match /readings/{id} {
      allow read, write: if true;
    }

    match /greenhouses/{id} {
      allow read, write: if true;
    }

    match /nodes/{id} {
      allow read, write: if true;
    }

    match /zones/{id} {
      allow read, write: if true;
    }

    match /plantProfiles/{id} {
      allow read, write: if true;
    }

    match /zoneAssignments/{id} {
      allow read, write: if true;
    }

    match /activityLogs/{id} {
      allow read, write: if true;
    }

    match /wateringEvents/{id} {
      allow read, write: if true;
    }

    match /alerts/{id} {
      allow read, write: if true;
    }

    match /tasks/{id} {
      allow read, write: if true;
    }

    match /notifications/{id} {
      allow read, write: if true;
    }
  }
}