rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // GreenMirror — open development rules.
    // All collections are listed explicitly so the scope is visible.
    // TODO: replace with auth-based rules before any public deployment.

    // Sensor readings (written by backend / ESP nodes)
    match /latestReadings/{id}   { allow read, write: if true; }
    match /readings/{id}         { allow read, write: if true; }

    // Greenhouse metadata
    match /greenhouses/{id}      { allow read, write: if true; }
    match /nodes/{id}            { allow read, write: if true; }
    match /zones/{id}            { allow read, write: if true; }

    // Plant profiles — one document per profile (custom + edited defaults)
    match /plantProfiles/{id}    { allow read, write: if true; }

    // Zone → plant assignments — one document per greenhouse
    match /zoneAssignments/{id}  { allow read, write: if true; }

    // Activity and watering logs (append-only in practice)
    match /activityLogs/{id}     { allow read, write: if true; }
    match /wateringEvents/{id}   { allow read, write: if true; }

    // Alerts and tasks (future use)
    match /alerts/{id}           { allow read, write: if true; }
    match /tasks/{id}            { allow read, write: if true; }
  }
}
